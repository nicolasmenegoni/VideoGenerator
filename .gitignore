```gitignore
# Compiled Python files
*.pyc
__pycache__/

# Virtual environments
venv/
.venv/
env/

# Logs
*.log

# Environment files
.env
.env.local
*.env.*

# Editor/IDE files
.vscode/
.idea/
*.swp
*.swo
*.tmp

# Build/dist directories
build/
dist/
target/

# Dependencies cache
node_modules/
.npm/
.yarn/
.pip/
.mypy_cache/
.pytest_cache/
.coverage
coverage/
htmlcov/
```